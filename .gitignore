# ───────────────────────────────────────
#  Kajal Singh — Portfolio .gitignore
# ───────────────────────────────────────

# ── Node / npm ──────────────────────────
node_modules/
.npm
.npmrc
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
*.tgz
.yarn-integrity

# ── Firebase ────────────────────────────
.firebase/
firebase-debug.log*
firebase-debug.*.log*
# Keep .firebaserc committed so all contributors deploy to the same project
# .firebaserc

# ── Environment / secrets ───────────────
.env
.env.local
.env.*.local
*.key
*.pem

# ── Build / generated output ────────────
dist/
build/
out/
.cache/
coverage/
.nyc_output/
lib-cov/

# ── Tooling temp files ──────────────────
*.log
logs/
pids/
*.pid
*.pid.lock
.lock-wscript
.grunt
.eslintcache
.node_repl_history
.dataconnect

# ── Testing / screenshots (dev only) ────
screenshot*.png
screenshot.js

# ── OS / editor artefacts ───────────────
.DS_Store
Thumbs.db
Desktop.ini
.vscode/
.idea/
*.swp
*.swo
*~
